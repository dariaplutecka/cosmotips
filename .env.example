# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=

# Stripe Webhook Secret — uruchom lokalnie: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
REPORT_EMAIL_FROM=
CONTACT_INBOX_EMAIL=

# Upstash Redis — https://console.upstash.com (wymagane dla rate limitingu)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dev only — ustaw true aby pominąć Stripe Checkout lokalnie
STRIPE_SKIP_PAYMENT_FOR_DEV=false
# Stripe webhook signing secret.
# For local development run: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=sk-...
STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SKIP_PAYMENT_FOR_DEV=false

# PDF report by email (Resend). Without these, the report still generates on the success page but no email is sent.
# Must match a current key from Resend → API Keys. "API key is invalid" = wrong key, revoked, or typo (no extra spaces).
RESEND_API_KEY=re_...
# Must use a domain verified in Resend (Dashboard → Domains), e.g. Name <reports@your-verified-domain.com>.
# For quick tests only, Resend provides: onboarding@resend.dev (see Resend docs — invalid_from_address means domain/sender mismatch).
REPORT_EMAIL_FROM="AstroApka <onboarding@resend.dev>"

# Upstash Redis credentials for API rate limiting.
# Create a Redis database at https://console.upstash.com, then copy REST URL and REST TOKEN from the database details.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

